# Database connection string
# Replace with your own PostgreSQL connection details
DATABASE_URL="postgresql://username:password@localhost:5432/envelope_budget"

# Server port
PORT=3001

# JWT secret key - Replace this with a strong secret in production!
JWT_SECRET="your-secret-key-change-this-in-production"

# Node environment (development, production, test)
NODE_ENV="development"

# Email configuration (for password resets)
# SMTP_HOST="smtp.example.com"
# SMTP_PORT=587
# SMTP_USER="user@example.com"
# SMTP_PASSWORD="your-smtp-password"
# EMAIL_FROM="noreply@envelopebudget.com" 